{
  "manifest_version": 3,
  "name": "QC Assistant DEV",
  "version": "2.0.0",
  "description": "QC Assistant Development Build",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://admin-v2.penpencil.co/*",
    "https://script.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://admin-v2.penpencil.co/*"],
      "js": ["content.js"]
    }
  ]
}
